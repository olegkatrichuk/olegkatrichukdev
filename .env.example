# Contact form email delivery (src/app/api/contact/route.ts).
# Without RESEND_API_KEY the form still works — it just logs instead of sending.

# Get a key at https://resend.com
RESEND_API_KEY=

# Sender. Must be an address on a domain verified in Resend.
# Leave unset to use Resend's test sender (onboarding@resend.dev),
# which only delivers to the Resend account owner.
CONTACT_FROM="Portfolio <onboarding@resend.dev>"

# Where contact submissions are delivered. Defaults to site.email.
CONTACT_TO=
